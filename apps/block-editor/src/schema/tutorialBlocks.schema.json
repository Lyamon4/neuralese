              "node": {
                "op": "field",
                "name": "alias"
              },
              "exprs": {
                "op": "computedKey",
                "template": "{property}",
                "value": {
                  "op": "template",
                  "value": "{operator} {expected}"
                }
              }
            }
          }
        }
      }
    },
