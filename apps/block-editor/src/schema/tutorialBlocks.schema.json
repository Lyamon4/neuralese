            "namespace": "node",
            "role": "reference"
          }
        },
        {
          "name": "property",
          "type": "slug",
          "label": "Property",
          "default": "neuron_count",
          "required": true
        },
        {
          "name": "operator",
          "type": "select",
          "label": "Comparison",
          "default": "==",
          "options": [
            {
              "label": "equals",
              "value": "=="
            },
            {
              "label": "at least",
              "value": ">="
            },
            {
              "label": "at most",
              "value": "<="
            },
            {
              "label": "greater than",
              "value": ">"
            },
            {
              "label": "less than",
              "value": "<"
            }
          ]
        },
        {
          "name": "expected",
          "type": "text",
          "label": "Value",
          "default": "8",
          "required": true
        }
      ],
      "connection": {
        "previous": "action",
        "next": "action"
      },
      "emit": {
        "op": "singleKeyMapping",
        "key": {
