{
  "schemaVersion": 2,
  "connectionShapes": {
    "lesson_step": {
      "width": 36,
      "height": 8,
      "pathLeft": " h 7 v 5 h 8 v -5 h 21 ",
      "pathRight": " h -21 v 5 h -8 v -5 h -7 "
    },
    "action": {
      "width": 36,
      "height": 8,
      "pathLeft": " c 2,0 3,1 4,2 l 4,4 c 1,1 2,2 4,2 h 12 c 2,0 3,-1 4,-2 l 4,-4 c 1,-1 2,-2 4,-2 ",
      "pathRight": " c -2,0 -3,1 -4,2 l -4,4 c -1,1 -2,2 -4,2 h -12 c -2,0 -3,-1 -4,-2 l -4,-4 c -1,-1 -2,-2 -4,-2 "
    },
    "quiz_option": {
      "width": 36,
      "height": 8,
      "pathLeft": " h 6 v 4 h 6 v 4 h 12 v -4 h 6 v -4 h 6 ",
      "pathRight": " h -6 v 4 h -6 v 4 h -12 v -4 h -6 v -4 h -6 "
    },
    "create_binding": {
      "width": 36,
      "height": 8,
      "pathLeft": " h 8 q 10,8 20,0 h 8 ",
      "pathRight": " h -8 q -10,8 -20,0 h -8 "
    },
    "requirement": {
      "width": 36,
      "height": 8,
      "pathLeft": " h 10 l 8,8 l 8,-8 h 10 ",
      "pathRight": " h -10 l -8,8 l -8,-8 h -10 "
    },
    "topology_node": {
      "width": 36,
      "height": 8,
      "pathLeft": " h 5 l 7,8 h 12 l 7,-8 h 5 ",
      "pathRight": " h -5 l -7,8 h -12 l -7,-8 h -5 "
    },
    "topology_edge": {
      "width": 36,
      "height": 8,
      "pathLeft": " h 8 v 8 h 20 v -8 h 8 ",
      "pathRight": " h -8 v 8 h -20 v -8 h -8 "
    },
    "highlight_target": {
      "width": 36,
      "height": 8,
      "pathLeft": " h 6 c 4,0 4,8 8,8 h 8 c 4,0 4,-8 8,-8 h 6 ",
      "pathRight": " h -6 c -4,0 -4,8 -8,8 h -8 c -4,0 -4,-8 -8,-8 h -6 "
    }
  },
  "blocks": [
    {
      "type": "lesson_root",
      "message": "When the main lesson flow starts",
      "category": "Lesson",
      "colour": "#2457ff",
      "kind": "hat",
      "role": "lesson_root",
      "toolboxVisible": false,
      "tooltip": "The single starting point for this lesson.",
      "fields": [],
      "stackInput": "flow",
      "connection": {
        "next": "lesson_step"
      },
      "emit": {
        "op": "object",
        "fields": {
          "flow": {
            "op": "children",
            "input": "flow"
          }
        }
      }
    },
    {
      "type": "lesson_step",
      "message": "Step %1 title %2 keep active %3",
      "category": "Lesson",
      "colour": "#2457ff",
      "kind": "statement",
      "tooltip": "A lesson step. Put teacher actions inside it.",
      "fields": [
        {
          "name": "id",
          "type": "slug",
          "label": "Step id",
          "default": "welcome",
          "required": true,
          "teacherVisible": false
        },
        {
          "name": "title",
          "type": "text",
          "label": "Step title",
          "default": "Welcome",
          "required": true
        },
        {
          "name": "persistent",
          "type": "bool",
          "label": "Persistent",
          "default": false
        }
      ],
      "connection": {
        "previous": "lesson_step",
        "next": "lesson_step"
      },
      "statementInputs": [
        {
          "name": "actions",
          "label": "Actions",
          "check": "action",
          "required": true
        }
      ],
      "emit": {
        "op": "singleKeyMapping",
        "key": {
          "op": "template",
          "value": "step {id}"
        },
        "value": {
          "op": "object",
          "fields": {
            "title": {
              "op": "field",
              "name": "title"
            },
            "persistent": {
              "op": "when",
              "field": "persistent",
              "equals": "TRUE",
              "then": {
                "op": "literal",
                "value": true
              }
            },
            "actions": {
              "op": "children",
              "input": "actions"
            }
          }
        }
      }
    },
    {
      "type": "lesson_branch",
      "message": "Branch %1",
      "category": "Flow",
      "colour": "#ffad0a",
      "kind": "hat",
      "role": "lesson_branch",
      "branchNameField": "name",
      "tooltip": "A separate named lesson flow that questions can open.",
      "fields": [
        {
          "name": "name",
          "type": "slug",
          "label": "Branch name",
          "default": "extra_help",
          "required": true
        }
      ],
      "stackInput": "steps",
      "connection": {
        "next": "lesson_step"
      },
      "emit": {
        "op": "computedKey",
        "template": "{name}",
        "value": {
          "op": "children",
          "input": "steps"
        }
      }
    },
    {
      "type": "action_explain",
      "message": "Say %1 wait %2 %3 %4",
      "category": "Teacher",
      "colour": "#00a8f5",
      "kind": "statement",
      "dsl": {
        "kind": "action",
        "key": "explain"
      },
      "tooltip": "Show explanation text to the student.",
      "fields": [
        {
          "name": "text",
          "type": "textarea",
          "label": "Message",
          "default": "Welcome to the lesson.",
          "required": true
        },
        {
          "name": "wait",
          "type": "wait_mode",
          "label": "Continue mode",
          "default": "next",
          "options": [
            {
              "label": "for Continue",
              "value": "next"
            },
            {
              "label": "not at all",
              "value": "none"
            },
            {
              "label": "for a time",
              "value": "time"
            }
          ]
        },
        {
          "name": "time",
          "type": "number",
          "label": "Seconds",
          "default": 1,
          "min": 0.1,
          "precision": 0.1,
          "required": true,
          "visibleWhen": {
            "field": "wait",
            "equals": "time"
          }
        },
        {
          "name": "time_unit",
          "type": "label",
          "label": "Seconds label",
          "default": "seconds",
          "visibleWhen": {
            "field": "wait",
            "equals": "time"
          }
        }
      ],
      "connection": {
        "previous": "action",
        "next": "action"
      },
      "emit": {
        "op": "singleKeyMapping",
        "key": {
          "op": "literal",
          "value": "explain"
        },
        "value": {
          "op": "object",
          "fields": {
            "text": {
              "op": "field",
              "name": "text",
              "coerce": "lines"
            },
            "wait": {
              "op": "field",
              "name": "wait",
              "default": "next"
            },
            "time": {
              "op": "when",
              "field": "wait",
              "equals": "time",
              "then": {
                "op": "field",
                "name": "time",
                "coerce": "number"
              }
            }
          }
        }
      }
    },
    {
      "type": "action_explain_button",
      "message": "Wait for the explanation button",
      "category": "Teacher",
      "colour": "#00a8f5",
      "kind": "statement",
      "dsl": {
        "kind": "action",
        "key": "explain_button"
      },
      "tooltip": "Wait until the student finishes the explanation.",
      "fields": [],
      "connection": {
        "previous": "action",
        "next": "action"
      },
      "emit": {
        "op": "singleKeyMapping",
        "key": {
          "op": "literal",
          "value": "explain_button"
        },
        "value": {
          "op": "literal",
          "value": {}
        }
      }
    },
    {
      "type": "action_explain_next",
      "message": "Hide explanation and continue",
      "category": "Teacher",
      "colour": "#00a8f5",
      "kind": "statement",
      "dsl": {
        "kind": "action",
        "key": "explain_next"
      },
      "tooltip": "Finish and hide the current explanation.",
      "fields": [],
      "connection": {
        "previous": "action",
        "next": "action"
      },
      "emit": {
        "op": "singleKeyMapping",
        "key": {
          "op": "literal",
          "value": "explain_next"
        },
        "value": {
          "op": "literal",
          "value": {}
        }
      }
    },
    {
      "type": "action_ask",
      "message": "Ask %1 options %2\nCorrect answers %3 show result %4 default branch %5",
      "category": "Teacher",
      "colour": "#00a8f5",
      "kind": "statement",
      "dsl": {
        "kind": "action",
        "key": "ask"
      },
      "tooltip": "Ask a multiple-choice question. Open Options to edit one answer per row.",
      "fields": [
        {
          "name": "head",
          "type": "textarea",
          "label": "Question",
          "default": "What is the correct answer?",
          "required": true
        },
        {
          "name": "options",
          "type": "option_list",
          "label": "Options",
          "default": "First option\nSecond option",
          "required": true
        },
        {
          "name": "correct",
          "type": "string_list",
          "label": "Correct option numbers",
          "default": "1",
          "required": true
        },
        {
          "name": "show",
          "type": "bool",
          "label": "Show result",
          "default": true
        },
        {
          "name": "default_branch",
          "type": "branch_ref",
          "label": "Default branch",
          "default": ""
        }
      ],
      "statementInputs": [
        {
          "name": "routes",
          "label": "Answer routes",
          "check": "quiz_option"
        }
      ],
      "connection": {
        "previous": "action",
        "next": "action"
      },
      "emit": {
        "op": "singleKeyMapping",
        "key": {
          "op": "literal",
          "value": "ask"
        },
        "value": {
          "op": "object",
          "fields": {
            "head": {
              "op": "field",
              "name": "head"
            },
            "options": {
              "op": "field",
              "name": "options",
              "coerce": "lines"
            },
            "correct": {
              "op": "field",
              "name": "correct",
              "coerce": "integerList"
            },
            "show": {
              "op": "field",
              "name": "show",
              "coerce": "boolean"
            },
            "on_answer": {
              "op": "childrenObject",
              "input": "routes",
              "omitEmpty": true
            },
            "default": {
              "op": "when",
              "field": "default_branch",
              "notEmpty": true,
              "then": {
                "op": "singleKeyMapping",
                "key": {
                  "op": "literal",
                  "value": "goto"
                },
                "value": {
                  "op": "field",
                  "name": "default_branch"
                }
              }
            }
          }
        }
      }
    },
    {
      "type": "quiz_answer_route",
      "message": "Answer %1 opens branch %2",
      "category": "Flow",
      "colour": "#ffad0a",
      "kind": "statement",
      "tooltip": "Route one answer to a named branch.",
      "fields": [
        {
          "name": "answer",
          "type": "number",
          "label": "Answer number",
          "default": 1,
          "min": 1,
          "precision": 1,
          "required": true
        },
        {
          "name": "branch",
          "type": "branch_ref",
          "label": "Branch",
          "default": "extra_help",
          "required": true
        }
      ],
      "connection": {
        "previous": "quiz_option",
        "next": "quiz_option"
      },
      "emit": {
        "op": "computedKey",
        "template": "{answer}",
        "value": {
          "op": "singleKeyMapping",
          "key": {
            "op": "literal",
            "value": "goto"
          },
          "value": {
            "op": "field",
            "name": "branch"
          }
        }
      }
    },
    {
